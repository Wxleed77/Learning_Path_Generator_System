# === PostgreSQL / Supabase ===
connection_string="postgresql://postgres.USER:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"

# === JWT ===
JWT_SECRET="your-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# === Groq (roadmap generation) ===
GROQ_API_KEY="gsk-..."
GROQ_MODEL="llama-3.3-70b-versatile"

# === OpenRouter (quiz generation) ===
# Sign up at https://openrouter.ai/keys
# Pick a free model at https://openrouter.ai/models (e.g. openai/gpt-4o-mini)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="openai/gpt-4o-mini"